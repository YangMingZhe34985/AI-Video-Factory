# ==============================================================
# AI Video Factory — 生产环境配置模板
# 使用前请将此文件复制为项目根目录的 .env.production 并填写真实值
# 注意: .env.production 已在 .gitignore 中，不会提交到代码库
# ==============================================================

# ── 基础安全配置 ───────────────────────────────────────────────
FLASK_ENV=production

# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-hex-secret
JWT_SECRET_KEY=replace-with-different-random-hex-secret

JWT_ACCESS_TOKEN_EXPIRES=3600        # access token 有效期（秒）
JWT_REFRESH_TOKEN_EXPIRES=2592000    # refresh token 有效期（秒，30天）
API_AUTH_REQUIRED=true
AUTO_REPAIR_SCHEMA=true

# ── MySQL 配置 ──────────────────────────────────────────────────
# 注意: docker-compose.yml 中 DATABASE_URL 会自动使用以下变量拼接
# 请勿在此处填写 DATABASE_URL（由 docker-compose environment 覆盖）
MYSQL_ROOT_PASSWORD=replace-with-strong-mysql-password
MYSQL_DATABASE=video_factory

# 数据库连接池（生产环境推荐值）
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_RECYCLE_SEC=300
DATABASE_POOL_TIMEOUT_SEC=30
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_CONNECT_TIMEOUT_SEC=10
DATABASE_READ_TIMEOUT_SEC=120
DATABASE_WRITE_TIMEOUT_SEC=120

# ── 文件存储 ────────────────────────────────────────────────────
STORAGE_ROOT=storage
UPLOAD_FOLDER=storage/uploads
MAX_CONTENT_LENGTH_MB=500

# ── 模型 API Keys（必填）────────────────────────────────────────
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
DEEPSEEK_API_KEY=replace-with-deepseek-api-key-if-used

# ── 模型 API 地址 ────────────────────────────────────────────────
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/api/v1
MODEL_ADAPTER_MODE=auto

# ── 默认模型 ────────────────────────────────────────────────────
DEFAULT_VIDEO_UNDERSTANDING_MODEL=qwen3.7-plus
DEFAULT_PROMPT_REWRITE_MODEL=deepseek-v4-flash
DEFAULT_T2V_MODEL=wan2.7-t2v
DEFAULT_IMAGE_MODEL=wan2.6-image
DEFAULT_R2V_FLASH_MODEL=wan2.6-r2v-flash
DEFAULT_I2V_MODEL=wan2.7-i2v
DEFAULT_I2I_TEST_IMAGE_MODEL=wan2.7-image
DEFAULT_I2I_TEST_I2V_MODEL=wan2.6-i2v-flash

# ── 工作流开关 ──────────────────────────────────────────────────
T2V_ENABLED=false
FIRST_FRAME_IMAGE_ENABLED=true
I2V_ENABLED=true
R2V_FLASH_ENABLED=false
I2I_TEST_ENABLED=false

# ── 并发与队列 ──────────────────────────────────────────────────
WORKFLOW_PARALLEL_ENABLED=true
WORKFLOW_MAX_PARALLEL_NODES=4
WORKFLOW_MAX_PARALLEL_POLLS=2
JOB_QUEUE_ENABLED=true
JOB_MAX_CONCURRENT_RUNS=2
JOB_QUEUE_POLL_INTERVAL_SEC=1
FAILURE_AGENT_ON_ERROR=true
FAILURE_AGENT_ENABLED=true
FAILURE_AGENT_MAX_RETRIES=1

# ── 超时配置 ────────────────────────────────────────────────────
REQUEST_TIMEOUT_SEC=180
DOWNLOAD_TIMEOUT_SEC=600
POLL_INTERVAL_SEC=10
MAX_POLL_ROUNDS=90
VIDEO_COMPRESSION_ENABLED=true
VIDEO_COMPRESSION_CRF=28
VIDEO_COMPRESSION_PRESET=medium
VIDEO_COMPRESSION_AUDIO_BITRATE=128k
FFMPEG_BINARY=

# ── Nginx 对外端口 ───────────────────────────────────────────────
# 修改此值可更改前端访问端口（如改为 8080 则访问 http://<IP>:8080）
HOST_PORT=80

# ── Gunicorn 参数 ────────────────────────────────────────────────
# worker 数量建议 = CPU核心数 × 2（最少 2）
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=300
